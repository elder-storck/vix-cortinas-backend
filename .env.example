# Porta do servidor (Railway define automaticamente)
PORT=3001

# URL(s) do frontend no Vercel (separe múltiplas por vírgula)
# Exemplo: https://vix-cortinas.vercel.app
FRONTEND_URL=

# Senha do admin inicial (gerada no primeiro start)
ADMIN_SENHA=

# Caminho do banco SQLite (use volume persistente no Railway)
# Exemplo: /data/db.sqlite
DB_PATH=
